PORT=3000

# ================= DATABASE =================
DATABASE_URL=postgresql://postgres.your_ref:your_password@your_host:6543/postgres

# ================= AUTH =================
JWT_SECRET=mysecretkey
JWT_EXPIRES_IN=1h

# ================= PAYMENT =================
PAYMENT_EXPIRES_IN_MINUTES=15
PAYMENT_PUBLIC_BASE_URL=https://your-public-domain.com

# ================= PAYOS =================
PAYOS_ENABLED=true
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
# Optional:
PAYOS_PARTNER_CODE=
PAYOS_BASE_URL=
PAYOS_WEBHOOK_PATH=/payments/payos/webhook
# Optional override URLs. If empty, backend auto-builds from PAYMENT_PUBLIC_BASE_URL:
# PAYOS_RETURN_URL => {PAYMENT_PUBLIC_BASE_URL}/payments/return/success?payment_code=...
# PAYOS_CANCEL_URL => {PAYMENT_PUBLIC_BASE_URL}/payments/return/cancel?payment_code=...
# PAYOS_WEBHOOK_URL => {PAYMENT_PUBLIC_BASE_URL}{PAYOS_WEBHOOK_PATH}
PAYOS_RETURN_URL=
PAYOS_CANCEL_URL=
PAYOS_WEBHOOK_URL=

# ================= BANK QR (fallback only if PAYOS disabled) =================
BANK_QR_ENABLED=true
BANK_QR_BANK_CODE=ICB
BANK_QR_BANK_NAME=VietinBank
BANK_QR_BANK_BIN=970415
BANK_QR_ACCOUNT_NUMBER=0936541966
BANK_QR_ACCOUNT_NAME=DAO DUNG VAN
BANK_QR_TEMPLATE=compact2

# ================= EMAIL (RESEND) =================
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=Vivudee <no-reply@example.com>
EMAIL_TEST=your_email@example.com

# ================= MOMO =================
MOMO_ENABLED=true
MOMO_PARTNER_CODE=MOMOBKUN20180529
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
# Set 1 if your amount is already VND. Use another rate only if your DB stores another currency.
MOMO_CONVERT_RATE=1
MOMO_REQUEST_TYPE=captureWallet
MOMO_REDIRECT_PATH=/payments/momo/return
MOMO_IPN_PATH=/payments/momo/ipn
MOMO_LANG=vi

